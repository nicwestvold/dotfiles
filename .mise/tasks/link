#!/usr/bin/env bash
#MISE description="Symlink dotfiles for specified apps"
set -euo pipefail

source "$(dirname "$0")/lib/mappings.sh"

if [[ $# -eq 0 ]]; then
  echo "Usage: mise run link <app>..."
  echo "Available apps: zsh tmux starship bat ghostty"
  exit 1
fi

for app in "$@"; do
  found=false
  for entry in "${MAPPINGS[@]}"; do
    IFS='|' read -r name src target <<< "$entry"
    [[ "$name" != "$app" ]] && continue
    found=true
    src_full="$DOTFILES_DIR/$src"

    if [[ -L "$target" && "$(readlink "$target")" == "$src_full" ]]; then
      echo "  $app: $target already linked"
      continue
    fi

    if [[ -e "$target" ]]; then
      echo "  $app: $target exists but is not the correct symlink, skipping"
      continue
    fi

    mkdir -p "$(dirname "$target")"
    ln -s "$src_full" "$target"
    echo "  $app: $target -> $src_full"
  done

  if [[ "$found" == false ]]; then
    echo "  Unknown app: $app"
  fi
done
